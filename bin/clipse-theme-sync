#!/usr/bin/env python3
import argparse
import configparser
import json
import os
import re
import subprocess
import sys
import time
from pathlib import Path

HOME = Path.home()
SCHEME_PATHS = [
    HOME / ".local/state/caelestia/scheme.json",
    HOME / ".cache/caelestia/scheme.json",
    HOME / ".config/caelestia/scheme.json",
]
SETTINGS_PATH = HOME / ".config/clipse-gui/settings.ini"
STATE_PATH = HOME / ".config/clipse-gui/last-gtk-theme"
GUI_CMD = HOME / ".local/bin/clipse-gui-fixed"
GUI_PATTERN = rf"(/usr/bin/clipse-gui|{re.escape(str(GUI_CMD))})( |$)"


def read_scheme():
    for path in SCHEME_PATHS:
        try:
            if path.exists():
                return json.loads(path.read_text(encoding="utf-8"))
        except Exception:
            continue
    return {}


def normalize_hex(value, fallback):
    if not value:
        return fallback
    text = str(value).strip().lstrip("#")
    if len(text) < 6:
        return fallback
    return "#" + text[:6]


def get_colour(colours, keys, fallback):
    for key in keys:
        if key in colours:
            return normalize_hex(colours[key], fallback)
    return fallback


def mode_from_gsettings():
    try:
        out = subprocess.check_output(
            ["gsettings", "get", "org.gnome.desktop.interface", "color-scheme"],
            text=True,
            stderr=subprocess.DEVNULL,
        ).lower()
        if "light" in out:
            return "light"
        if "dark" in out:
            return "dark"
    except Exception:
        pass
    return "dark"


def theme_from_mode(mode):
    return "adw-gtk3" if mode == "light" else "adw-gtk3-dark"


def desired_values(scheme):
    mode = str(scheme.get("mode") or mode_from_gsettings()).lower()
    if mode not in {"light", "dark"}:
        mode = mode_from_gsettings()

    colours = scheme.get("colours") if isinstance(scheme.get("colours"), dict) else {}
    if mode == "light":
        accent_fallback = "#6750a4"
        visual_fallback = "#625b71"
    else:
        accent_fallback = "#d0bcff"
        visual_fallback = "#ccc2dc"

    accent = get_colour(colours, ["primary", "accent", "klink"], accent_fallback)
    secondary = get_colour(colours, ["secondary", "primaryContainer", "klinkSelection"], accent)
    visual = get_colour(colours, ["tertiary", "mauve", "secondary"], visual_fallback)

    return mode, {
        "border_radius": "6",
        "accent_color": accent,
        "selection_color": secondary,
        "selection_bg_color": secondary,
        "hover_color": secondary,
        "hover_bg_color": secondary,
        "visual_mode_color": visual,
        "background_transparent": "False",
    }


def update_settings(values):
    SETTINGS_PATH.parent.mkdir(parents=True, exist_ok=True)
    config = configparser.ConfigParser()
    config.optionxform = str
    config.read(SETTINGS_PATH)

    if not config.has_section("Style"):
        config.add_section("Style")

    changed = False
    for key, value in values.items():
        if config.get("Style", key, fallback=None) != value:
            config.set("Style", key, value)
            changed = True

    if changed or not SETTINGS_PATH.exists():
        with SETTINGS_PATH.open("w", encoding="utf-8") as handle:
            config.write(handle)
    return changed


def update_theme_state(gtk_theme):
    old_theme = ""
    try:
        old_theme = STATE_PATH.read_text(encoding="utf-8").strip()
    except Exception:
        pass

    changed = old_theme != gtk_theme
    if changed:
        STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
        STATE_PATH.write_text(gtk_theme + "\n", encoding="utf-8")
    return changed


def gui_running():
    return subprocess.run(
        ["pgrep", "-f", GUI_PATTERN],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    ).returncode == 0


def gui_visible():
    try:
        clients = subprocess.check_output(
            ["hyprctl", "clients"],
            text=True,
            stderr=subprocess.DEVNULL,
        )
    except Exception:
        return False
    return "class: clipse" in clients.lower() or "title: clipse" in clients.lower()


def kill_gui():
    subprocess.run(
        ["pkill", "-f", GUI_PATTERN],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def refresh_running(gtk_theme):
    if not gui_running():
        return

    was_visible = gui_visible()
    if not was_visible:
        return

    kill_gui()
    time.sleep(0.12)

    if GUI_CMD.exists():
        env = os.environ.copy()
        env["GTK_THEME"] = gtk_theme
        with open("/tmp/clipse-gui.log", "ab", buffering=0) as log:
            subprocess.Popen(
                [str(GUI_CMD)],
                stdout=log,
                stderr=subprocess.STDOUT,
                env=env,
                start_new_session=True,
            )


def main():
    parser = argparse.ArgumentParser(description="Sync Clipse GUI with Caelestia colours.")
    parser.add_argument("--gtk-theme", action="store_true", help="print the GTK theme after syncing")
    parser.add_argument("--refresh-running", action="store_true", help="restart Clipse GUI if it is running")
    args = parser.parse_args()

    scheme = read_scheme()
    mode, values = desired_values(scheme)
    gtk_theme = theme_from_mode(mode)
    changed = update_settings(values)
    theme_changed = update_theme_state(gtk_theme)

    if args.refresh_running and (changed or theme_changed):
        refresh_running(gtk_theme)

    if args.gtk_theme:
        print(gtk_theme)


if __name__ == "__main__":
    sys.exit(main())
