#!/usr/bin/env bash
set -u

if quickshell ipc -c caelestia call launcher openWallpapers >/tmp/caelestia-wallpaper-menu.log 2>&1; then
    exit 0
fi

if [[ "$(quickshell ipc -c caelestia call drawers isOpen launcher 2>/dev/null || echo 0)" != "1" ]]; then
    quickshell ipc -c caelestia call drawers toggle launcher >/dev/null 2>&1 || true
fi

sleep 0.25
wtype '>wallpaper ' >/dev/null 2>&1 || true
